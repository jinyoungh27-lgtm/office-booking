# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (Email) ─────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=bookings@yourdomain.com   # Must be verified in Resend

# ── Admin Auth ─────────────────────────────────────────────────
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SESSION_TOKEN=choose-a-long-random-string-eg-abc123xyz789  # used as cookie value
ADMIN_EMAIL=your-email@example.com          # Where booking notifications go

# ── App URL ────────────────────────────────────────────────────
# For local dev:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# For production (after Vercel deploy):
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
